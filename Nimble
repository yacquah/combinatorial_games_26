import numpy as np
import matplotlib.pyplot as plt
from numba import njit

@njit(cache=True)
def generate_Wx(Wx, desired_level):
    """Iteratively build the instant-winner sheet W_x up to ``desired_level``."""
    if desired_level == 0:
        return Wx

    for _ in range(1, desired_level + 1):
        Wx |= supermex(Wx)
    return Wx

@njit(cache=True)
def _find(next_free, r):
    """Union-find lookup: smallest row index >= r not yet claimed this pass."""
    while next_free[r] != r:
        next_free[r] = next_free[next_free[r]]
        r = next_free[r]
    return r

@njit(cache=True)
def supermex(Wx):
    """Compute the Knight-Wythoff supermex sheet M(Wx).

    This integrates both straight line axes and skewed diagonal vector shifts
    to calculate where the next cluster of losing positions must fall.
    """
    grid_size = Wx.shape[0]
    MWx = np.zeros((grid_size, grid_size), dtype=np.bool_)

    # next_free[r] points to the smallest unclaimed row >= r
    next_free = np.empty(grid_size + 1, dtype=np.int64)
    for r in range(grid_size + 1):
        next_free[r] = r

    for y in range(grid_size):
        z = _find(next_free, 0)
        
        # Look for the first row index that isn't blocked by straight lines 
        # or previous diagonal calculation histories
        while z < grid_size and Wx[z, y]:
            z = _find(next_free, z + 1)

        if z == grid_size:
            continue

        MWx[z, y] = True
        next_free[z] = z + 1

    return MWx

def plot_sheet(matrix, is_winner, level):
    """Renders a grid visualization matching your GUI format.
    
    Plots y on the horizontal axis and z on the vertical axis.
    Active cells are filled in black.
    """
    grid_size = matrix.shape[0]
    
    # Create background display grid (1.0 = White)
    display_grid = np.ones((grid_size, grid_size), dtype=np.float32)
    
    # Fill in active states as black (0.0)
    for y in range(grid_size):
        for z in range(grid_size):
            if matrix[z, y]:
                display_grid[z, y] = 0.0

    # Setup the Matplotlib figure
    fig, ax = plt.subplots(figsize=(7, 6))
    
    # origin='lower' keeps (0,0) at the bottom-left corner
    ax.imshow(display_grid, cmap='gray', origin='lower', extent=[-0.5, grid_size-0.5, -0.5, grid_size-0.5])
    
    # Set up crisp grid lines dividing each cell integer block
    ax.set_xticks(np.arange(0, grid_size, 2))
    ax.set_yticks(np.arange(0, grid_size, 2))
    ax.set_xticks(np.arange(-0.5, grid_size, 1), minor=True)
    ax.set_yticks(np.arange(-0.5, grid_size, 1), minor=True)
    
    ax.grid(which='minor', color='black', linestyle='-', linewidth=0.5)
    ax.tick_params(which='minor', bottom=False, left=False)
    
    # Title and Labels
    sheet_name = f"W{level}" if is_winner else f"L{level}"
    ax.set_title(f"{sheet_name} with size {grid_size}")
    ax.set_xlabel("y")
    ax.set_ylabel("z")
    
    plt.show()

def main():
    """Prompt for a Knight-Wythoff sheet request, compute it, and display."""
    grid_size = int(input("Size of the grid you want to see:\n"))
    is_winner = input("Winner or loser? (W/L)\n").strip().upper() == 'W'
    desired_level = int(input("x-level?\n"))

    Wx = np.zeros((grid_size, grid_size), dtype=np.bool_)
    Wx = generate_Wx(Wx, desired_level)

    if is_winner:
        plot_sheet(Wx, True, desired_level)
    else:
        Lx = supermex(Wx)
        plot_sheet(Lx, False, desired_level)

if __name__ == "__main__":
    main()


