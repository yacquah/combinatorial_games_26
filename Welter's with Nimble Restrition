"""Generate and display finite instant-winner and loser sheets for Modified Welter.

This script computes two-dimensional slices of a 3-coin variant of Welter's Game
enforcing the Nimble 'no-passing/no-jumping' rule using a modified ``supermex`` 
operator. It renders the calculated lattices visually via Matplotlib.
"""

import numpy as np
import matplotlib.pyplot as plt
from numba import njit

@njit(cache=True)
def generate_Wx(Wx, desired_level):
    """Iteratively build the instant-winner sheet W_x up to ``desired_level``."""
    if desired_level == 0:
        return Wx

    for _ in range(1, desired_level + 1):
        Wx |= supermex(Wx)
    return Wx

@njit(cache=True)
def _find(next_free, r):
    """Union-find lookup: smallest row index >= r not yet claimed this pass."""
    while next_free[r] != r:
        next_free[r] = next_free[next_free[r]]
        r = next_free[r]
    return r

@njit(cache=True)
def supermex(Wx):
    """Compute the supermex sheet M(Wx) under the Nimble physical-blocking rule.

    Ensures that coordinates are tightly bound by the condition x < y < z, 
    preventing pieces from crossing paths or landing on top of each other.
    """
    grid_size = Wx.shape[0]
    MWx = np.zeros((grid_size, grid_size), dtype=np.bool_)

    # next_free[r] tracks the next available unclaimed row index
    next_free = np.empty(grid_size + 1, dtype=np.int64)
    for r in range(grid_size + 1):
        next_free[r] = r

    for y in range(grid_size):
        # Because coins cannot pass or jump each other, Row z MUST be strictly greater than Column y
        start_row = y + 1
        if start_row >= grid_size:
            continue
            
        z = _find(next_free, start_row)
        
        while z < grid_size and Wx[z, y]:
            z = _find(next_free, z + 1)

        if z == grid_size:
            continue

        MWx[z, y] = True
        next_free[z] = z + 1

    return MWx

def plot_sheet(matrix, is_winner, level):
    """Renders a grid visualization matching your project's interface format.
    
    - y-axis maps horizontally.
    - z-axis maps vertically.
    - Dead zones created by the no-passing rules are natively preserved.
    """
    grid_size = matrix.shape[0]
    
    # Initialize background grid canvas (1.0 = White background)
    display_grid = np.ones((grid_size, grid_size), dtype=np.float32)
    
    # Enforce visual dead zones and active P/N markers
    for y in range(grid_size):
        for z in range(grid_size):
            # If the state violates x < y < z, it's an illegal space (leave white/empty)
            if y <= level or z <= y:
                continue
            
            # Draw active positions as solid black blocks (0.0)
            if matrix[z, y]:
                display_grid[z, y] = 0.0

    # Initialize Matplotlib Figure
    fig, ax = plt.subplots(figsize=(7, 6))
    
    # origin='lower' pins (0,0) down to the bottom-left corner
    ax.imshow(display_grid, cmap='gray', origin='lower', extent=[-0.5, grid_size-0.5, -0.5, grid_size-0.5])
    
    # Setup crisp sharp grid outlines bounding individual cells
    ax.set_xticks(np.arange(0, grid_size, 2))
    ax.set_yticks(np.arange(0, grid_size, 2))
    ax.set_xticks(np.arange(-0.5, grid_size, 1), minor=True)
    ax.set_yticks(np.arange(-0.5, grid_size, 1), minor=True)
    
    ax.grid(which='minor', color='black', linestyle='-', linewidth=0.5)
    ax.tick_params(which='minor', bottom=False, left=False)
    
    # Graph Details
    sheet_name = f"W{level}" if is_winner else f"L{level}"
    ax.set_title(f"{sheet_name} with size {grid_size}")
    ax.set_xlabel("y")
    ax.set_ylabel("z")
    
    plt.show()

def main():
    """Prompt for the custom game state evaluation configuration and map the result."""
    grid_size = int(input("Size of the grid you want to see:\n"))
    is_winner = input("Winner or loser? (W/L)\n").strip().upper() == 'W'
    desired_level = int(input("x-level?\n"))

    Wx = np.zeros((grid_size, grid_size), dtype=np.bool_)
    Wx = generate_Wx(Wx, desired_level)

    if is_winner:
        plot_sheet(Wx, True, desired_level)
    else:
        Lx = supermex(Wx)
        plot_sheet(Lx, False, desired_level)

if __name__ == "__main__":
    main()